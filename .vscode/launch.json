{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Backend",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/src/backend/src/Mahjong.Autotable.Api/bin/Debug/net10.0/Mahjong.Autotable.Api.dll",
      "cwd": "${workspaceFolder}/src/backend/src/Mahjong.Autotable.Api",
      "preLaunchTask": "backend: build",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on:\\s+(https?://\\S+)"
      }
    },
    {
      "name": "Frontend Modern (Vite)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm install && npm run dev",
      "cwd": "${workspaceFolder}/src/frontend/modern"
    },
    {
      "name": "Backend + Autotable Baseline",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/src/backend/src/Mahjong.Autotable.Api/bin/Debug/net10.0/Mahjong.Autotable.Api.dll",
      "cwd": "${workspaceFolder}/src/backend/src/Mahjong.Autotable.Api",
      "preLaunchTask": "backend: build",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ],
  "compounds": [
    {
      "name": "F5 Full Stack (Backend + Modern Frontend)",
      "configurations": [
        ".NET Backend",
        "Frontend Modern (Vite)"
      ]
    }
  ]
}
